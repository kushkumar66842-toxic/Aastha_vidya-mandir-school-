::view-transition-old(sb) { height: 100%; }

::view-transition-new(sb) { height: 100%; }

@keyframes sb-slide-down-fade-in { 
  0% { transform: scale(0.5) translateY(-50px); opacity: 0; }
  20% { opacity: 0; }
  100% { transform: scale(1) translateY(0px); opacity: 1; }
}

@keyframes sb-slide-up-fade-out { 
  0% { transform: scale(1) translateY(0px); opacity: 1; }
  20% { opacity: 0; }
  100% { transform: scale(0.5) translateY(-50px); opacity: 0; }
}

@keyframes ubi-fade-in { 
  0% { transform: translateY(-20px); opacity: 0; }
  20% { opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes ubi-fade-out { 
  0% { transform: translateY(0px); opacity: 1; }
  20% { opacity: 0; }
  100% { transform: translateY(-20px); opacity: 0; }
}

html:active-view-transition-type(aimc)::view-transition-new(sb), html:active-view-transition-type(aimc)::view-transition-old(sb) { height: 100%; }

html:active-view-transition-type(aimc)::view-transition-old(sb):only-child { animation: 0.5s cubic-bezier(0.38, 0.72, 0, 1) 0s 1 normal forwards running sb-slide-up-fade-out; }

html:active-view-transition-type(aimc)::view-transition-new(sb):only-child { animation: 0.5s cubic-bezier(0.38, 0.72, 0, 1) 0s 1 normal forwards running sb-slide-down-fade-in; }

html:active-view-transition-type(aimc)::view-transition-new(mb), html:active-view-transition-type(aimc)::view-transition-old(mb) { width: auto; animation-duration: 0.5s; animation-timing-function: cubic-bezier(0.38, 0.72, 0, 1); }

html:active-view-transition-type(aimc)::view-transition-group(*) { transform-origin: left top; }

html:active-view-transition-type(aimc)::view-transition-new(ubi), html:active-view-transition-type(aimc)::view-transition-old(ubi) { width: 100%; height: 100%; animation-duration: 0.5s; animation-timing-function: cubic-bezier(0.38, 0.72, 0, 1); }

html:active-view-transition-type(aimc)::view-transition-old(ubi):only-child { animation: 0.5s cubic-bezier(0.38, 0.72, 0, 1) 0s 1 normal none running ubi-fade-out; }

html:active-view-transition-type(aimc)::view-transition-new(ubi):only-child { animation: 0.5s cubic-bezier(0.38, 0.72, 0, 1) 0s 1 normal none running ubi-fade-in; }
