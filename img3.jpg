.yDmH0d { width: auto !important; }

.hg3Lgc { display: inline-block; position: relative; width: 28px; height: 28px; }

.eBrXtc { position: absolute; width: 0px; height: 0px; overflow: hidden; }

.JdM54e { width: 100%; height: 100%; }

.hg3Lgc.isActive .JdM54e { animation: 1568ms linear 0s infinite normal none running spinner-container-rotate; }

.aopPX { position: absolute; width: 100%; height: 100%; opacity: 0; }

.ZqnFk { border-color: rgb(66, 133, 244); }

.fxjES { border-color: rgb(219, 68, 55); }

.ZHXbZe { border-color: rgb(244, 180, 0); }

.fDBOYb { border-color: rgb(15, 157, 88); }

.hg3Lgc.isActive .aopPX.ZqnFk { animation: 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-fill-unfill-rotate, 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-blue-fade-in-out; }

.hg3Lgc.isActive .aopPX.fxjES { animation: 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-fill-unfill-rotate, 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-red-fade-in-out; }

.hg3Lgc.isActive .aopPX.ZHXbZe { animation: 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-fill-unfill-rotate, 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-yellow-fade-in-out; }

.hg3Lgc.isActive .aopPX.fDBOYb { animation: 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-fill-unfill-rotate, 5332ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-green-fade-in-out; }

.LqC3Y { position: absolute; box-sizing: border-box; top: 0px; left: 45%; width: 10%; height: 100%; overflow: hidden; border-color: inherit; }

.LqC3Y .kPEoYc { width: 1000%; left: -450%; }

.e2XBBf { display: inline-block; position: relative; width: 50%; height: 100%; overflow: hidden; border-color: inherit; }

.e2XBBf .kPEoYc { width: 200%; }

.kPEoYc { position: absolute; inset: 0px; box-sizing: border-box; height: 100%; border-width: 3px; border-style: solid; border-top-color: inherit; border-right-color: inherit; border-left-color: inherit; border-bottom-color: transparent; border-radius: 50%; animation: auto ease 0s 1 normal none running none; }

.e2XBBf.uEtL3 .kPEoYc { border-right-color: transparent; transform: rotate(129deg); }

.e2XBBf.QR7YS .kPEoYc { left: -100%; border-left-color: transparent; transform: rotate(-129deg); }

.hg3Lgc.isActive .e2XBBf.uEtL3 .kPEoYc { animation: 1333ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-left-spin; }

.hg3Lgc.isActive .e2XBBf.QR7YS .kPEoYc { animation: 1333ms cubic-bezier(0.4, 0, 0.2, 1) 0s infinite normal both running spinner-right-spin; }

.hg3Lgc.sf4e6b .JdM54e { animation: 1568ms linear 0s infinite normal none running spinner-container-rotate, 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal none running spinner-fade-out; }

@keyframes spinner-container-rotate { 
  100% { transform: rotate(1turn); }
}

@keyframes spinner-fill-unfill-rotate { 
  12.5% { transform: rotate(135deg); }
  25% { transform: rotate(270deg); }
  37.5% { transform: rotate(405deg); }
  50% { transform: rotate(540deg); }
  62.5% { transform: rotate(675deg); }
  75% { transform: rotate(810deg); }
  87.5% { transform: rotate(945deg); }
  100% { transform: rotate(3turn); }
}

@keyframes spinner-blue-fade-in-out { 
  0% { opacity: 0.99; }
  25% { opacity: 0.99; }
  26% { opacity: 0; }
  89% { opacity: 0; }
  90% { opacity: 0.99; }
  100% { opacity: 0.99; }
}

@keyframes spinner-red-fade-in-out { 
  0% { opacity: 0; }
  15% { opacity: 0; }
  25% { opacity: 0.99; }
  50% { opacity: 0.99; }
  51% { opacity: 0; }
}

@keyframes spinner-yellow-fade-in-out { 
  0% { opacity: 0; }
  40% { opacity: 0; }
  50% { opacity: 0.99; }
  75% { opacity: 0.99; }
  76% { opacity: 0; }
}

@keyframes spinner-green-fade-in-out { 
  0% { opacity: 0; }
  65% { opacity: 0; }
  75% { opacity: 0.99; }
  90% { opacity: 0.99; }
  100% { opacity: 0; }
}

@keyframes spinner-left-spin { 
  0% { transform: rotate(130deg); }
  50% { transform: rotate(-5deg); }
  100% { transform: rotate(130deg); }
}

@keyframes spinner-right-spin { 
  0% { transform: rotate(-130deg); }
  50% { transform: rotate(5deg); }
  100% { transform: rotate(-130deg); }
}

@keyframes spinner-fade-out { 
  0% { opacity: 0.99; }
  100% { opacity: 0; }
}

.Ew9oWb { display: block; position: relative; }

.FAZ4xe { display: block; overflow-x: auto; scrollbar-width: none; position: relative; white-space: nowrap; }

.FAZ4xe::-webkit-scrollbar { display: none; }

.sjmfFd { overflow: hidden; }

.fVVMnd { height: 100%; }

.v3CIrf { min-width: 26px; padding: 0px; margin: 0px; }

.sal6Qd { display: flex; flex-shrink: 0; align-items: stretch; }

.PKhmud { flex-shrink: 0; }

.NMm5M { fill: currentcolor; flex-shrink: 0; }

[dir="rtl"] .hhikbc { transform: scaleX(-1); }

.GY1Nfe { display: inline-flex; place-content: center; place-items: center; }

html[dir="rtl"] .giSqbe { transform: scaleX(-1); }

.mZB8Yc { display: inline; }

@keyframes mdc-ripple-fg-radius-in { 
  0% { animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transform: translate(var(--mdc-ripple-fg-translate-start,0)) scale(1); }
  100% { transform: translate(var(--mdc-ripple-fg-translate-end,0)) scale(var(--mdc-ripple-fg-scale,1)); }
}

@keyframes mdc-ripple-fg-opacity-in { 
  0% { animation-timing-function: linear; opacity: 0; }
  100% { opacity: var(--mdc-ripple-fg-opacity,0); }
}

@keyframes mdc-ripple-fg-opacity-out { 
  0% { animation-timing-function: linear; opacity: var(--mdc-ripple-fg-opacity,0); }
  100% { opacity: 0; }
}

.wcpS5e { --mdc-ripple-fg-size: 0; --mdc-ripple-left: 0; --mdc-ripple-top: 0; --mdc-ripple-fg-scale: 1; --mdc-ripple-fg-translate-end: 0; --mdc-ripple-fg-translate-start: 0; -webkit-tap-highlight-color: rgba(0, 0, 0, 0); will-change: transform, opacity; position: relative; outline: none; overflow: hidden; }

.wcpS5e::after, .wcpS5e::before { position: absolute; border-radius: 50%; opacity: 0; pointer-events: none; content: ""; }

.wcpS5e::before { transition: opacity 15ms linear, background-color 15ms linear; z-index: var(--mdc-ripple-z-index,1); }

.wcpS5e::after { z-index: var(--mdc-ripple-z-index,0); }

.wcpS5e.kiqhKd::before { transform: scale(var(--mdc-ripple-fg-scale,1)); }

.wcpS5e.kiqhKd::after { top: 0px; left: 0px; transform: scale(0); transform-origin: center center; }

.wcpS5e.MkHxwb::after { top: var(--mdc-ripple-top,0); left: var(--mdc-ripple-left,0); }

.wcpS5e.y5phv::after { animation: 225ms ease 0s 1 normal forwards running mdc-ripple-fg-radius-in, 75ms ease 0s 1 normal forwards running mdc-ripple-fg-opacity-in; }

.wcpS5e.qKnE3c::after { animation: 0.15s ease 0s 1 normal none running mdc-ripple-fg-opacity-out; transform: translate(var(--mdc-ripple-fg-translate-end,0)) scale(var(--mdc-ripple-fg-scale,1)); }

.wcpS5e::after, .wcpS5e::before { top: -50%; left: -50%; width: 200%; height: 200%; }

.wcpS5e.kiqhKd::after { width: var(--mdc-ripple-fg-size,100%); height: var(--mdc-ripple-fg-size,100%); }

.MkHxwb, .wcpS5e[data-mdc-ripple-is-unbounded] { overflow: visible; }

.MkHxwb::after, .MkHxwb::before, .wcpS5e[data-mdc-ripple-is-unbounded]::after, .wcpS5e[data-mdc-ripple-is-unbounded]::before { top: 0px; left: 0px; width: 100%; height: 100%; }

.MkHxwb.kiqhKd::after, .MkHxwb.kiqhKd::before, .wcpS5e[data-mdc-ripple-is-unbounded].kiqhKd::after, .wcpS5e[data-mdc-ripple-is-unbounded].kiqhKd::before { top: var(--mdc-ripple-top,0); left: var(--mdc-ripple-left,0); width: var(--mdc-ripple-fg-size,100%); height: var(--mdc-ripple-fg-size,100%); }

.MkHxwb.kiqhKd::after, .wcpS5e[data-mdc-ripple-is-unbounded].kiqhKd::after { width: var(--mdc-ripple-fg-size,100%); height: var(--mdc-ripple-fg-size,100%); }

.wcpS5e::after, .wcpS5e::before { background-color: var(--mdc-ripple-color,#000); }

.wcpS5e.K1vCLe::before, .wcpS5e:hover::before { opacity: var(--mdc-ripple-hover-opacity,.04); }

.wcpS5e.J0GYAf::before, .wcpS5e:not(.kiqhKd):focus::before { transition-duration: 75ms; opacity: var(--mdc-ripple-focus-opacity,.12); }

.wcpS5e:not(.kiqhKd)::after { transition: opacity 0.15s linear; }

.wcpS5e:not(.kiqhKd):active::after { transition-duration: 75ms; opacity: var(--mdc-ripple-press-opacity,.12); }

.wcpS5e.kiqhKd { --mdc-ripple-fg-opacity: var(--mdc-ripple-press-opacity,0.12); }

.CeiTH { font-size: 24px; width: 48px; height: 48px; padding: 12px; }

.CeiTH.s4XJvf .ti8Tdd { width: 40px; height: 40px; margin: 4px; }

.CeiTH.s4XJvf .z59NDd { max-height: 40px; max-width: 40px; }

.CeiTH:disabled { color: var(--mdc-theme-text-disabled-on-light,rgba(0,0,0,.38)); }

.CeiTH img, .CeiTH svg { width: 24px; height: 24px; }

.CeiTH { display: inline-block; position: relative; box-sizing: border-box; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; outline: none; background-color: transparent; fill: currentcolor; color: inherit; text-decoration: none; cursor: pointer; user-select: none; z-index: 0; overflow: visible; }

.CeiTH .q7vLSb { position: absolute; top: 50%; height: 48px; left: 50%; width: 48px; transform: translate(-50%, -50%); }

@media screen and (forced-colors: active) {
  .CeiTH.J0GYAf .z59NDd, .CeiTH:not(.kiqhKd):focus .z59NDd { display: block; }
}

.CeiTH:disabled { cursor: default; pointer-events: none; }

.CeiTH[hidden] { display: none; }

.TMrdXb { align-items: center; display: inline-flex; justify-content: center; }

.z59NDd { pointer-events: none; border: 2px solid transparent; border-radius: 6px; box-sizing: content-box; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); height: 100%; width: 100%; display: none; }

@media screen and (forced-colors: active) {
  .z59NDd { border-color: canvastext; }
}

.z59NDd::after { content: ""; border: 2px solid transparent; border-radius: 8px; display: block; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); height: calc(100% + 4px); width: calc(100% + 4px); }

@media screen and (forced-colors: active) {
  .z59NDd::after { border-color: canvastext; }
}

.nfAwHe { display: inline-block; }

.JTuWCb .nfAwHe, .nfAwHe.fv3ppc { display: none; }

